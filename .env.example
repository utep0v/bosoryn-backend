# === DATABASE ===
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=bosoryn

# === SERVER ===
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=true
CORS_ORIGIN=https://api.your-domain.kz,https://your-domain.kz

# === JWT ===
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=24h

JWT_REFRESH_SECRET=refreshsupersecret
JWT_REFRESH_EXPIRES_IN=30d

# === ADMIN ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# === BASE URL ===
BASE_URL=https://api.your-domain.kz

# === DATABASE OPTIONS ===
DB_SYNCHRONIZE=false
DB_SSL=false

# === SMTP ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=school-bot@example.com
SMTP_PASS=change-me
SMTP_FROM=school-bot@example.com

# === WHATSAPP (BAILEYS) ===
WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=data/whatsapp-auth
WHATSAPP_PAIRING_PHONE_NUMBER=
WHATSAPP_PRINT_QR=false
WHATSAPP_LOG_LEVEL=silent
